#include <iostream>
#include <cmath>

using namespace std;

const double EPSILON = 1e-8; // 부동 소수점 오차 방지를 위한 작은 값

class Vec {
public:
    double x, y, z;
    Vec() : x(0), y(0), z(0) {}
    Vec(double x, double y, double z) : x(x), y(y), z(z) {}

    Vec operator+(const Vec& v) const { return { x + v.x, y + v.y, z + v.z }; }
    Vec operator-(const Vec& v) const { return { x - v.x, y - v.y, z - v.z }; }
    Vec operator*(double s) const { return { x * s, y * s, z * s }; }

    double dot(const Vec& v) const { return x * v.x + y * v.y + z * v.z; }
    Vec cross(const Vec& v) const {
        return { y * v.z - z * v.y, z * v.x - x * v.z, x * v.y - y * v.x };
    }
};

class Triangle {
public:
    Vec A, B, C;
    Triangle(const Vec& A, const Vec& B, const Vec& C) : A(A), B(B), C(C) {}

    // 직선 P1 P2와 삼각형의 교차 여부를 판별하는 함수
    bool intersect(const Vec& P1, const Vec& P2) const {
        Vec edge1 = B - A;
        Vec edge2 = C - A;
        Vec dir = P2 - P1; // 직선의 방향 벡터

        Vec pvec = dir.cross(edge2);
        double det = edge1.dot(pvec);

        // det가 0에 가깝다면 직선과 삼각형 평면이 평행함
        if (abs(det) < EPSILON) return false;

        double invDet = 1.0 / det;
        Vec tvec = P1 - A;

        // 무게 중심 좌표 u 계산
        double u = tvec.dot(pvec) * invDet;
        if (u < 0.0 || u > 1.0) return false;

        Vec qvec = tvec.cross(edge1);

        // 무게 중심 좌표 v 계산
        double v = dir.dot(qvec) * invDet;
        if (v < 0.0 || u + v > 1.0) return false;

        // 직선의 파라미터 t 계산 (P1에서 P2 사이의 거리 비율)
        double t = edge2.dot(qvec) * invDet;

        // t가 0 이상이라면 P1에서 시작하여 P2 방향으로 향하는 반직선 내에서 교차함
        return (t >= 0.0);
    }
};

int main() {
    Vec pA, pB, pC, p1, p2;

    cout << "삼각형 꼭짓점 A, B, C 입력 (x1 y1 z1 x2 y2 z2 x3 y3 z3):" << endl;
    cin >> pA.x >> pA.y >> pA.z >> pB.x >> pB.y >> pB.z >> pC.x >> pC.y >> pC.z;
    Triangle tri(pA, pB, pC);

    cout << "시작점 P1과 끝점 P2 입력(x1 y1 z1 x2 y2 z2):" << endl;
    cin >> p1.x >> p1.y >> p1.z >> p2.x >> p2.y >> p2.z;

    if (tri.intersect(p1, p2)) {
        cout << "결과: 1 (교차함)" << endl;
    }
    else {
        cout << "결과: 0 (교차하지 않음)" << endl;
    }

    return 0;
}
